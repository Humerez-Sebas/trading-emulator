# Copia este archivo a `.env` y completa los valores reales (usado por
# `pipeline/fill_r2.py --env <ruta>` o exportando estas variables en el shell).
# NUNCA commitees el `.env` real.

# --- Cloudflare R2 (pipeline MT5 -> Parquet -> R2) ---
# ID de la cuenta de Cloudflare (consola R2 -> Overview).
R2_ACCOUNT_ID=
# Nombre del bucket R2 donde se publican los Parquet + manifest.json.
R2_BUCKET_NAME=
# Access Key ID del token R2 (con permisos de lectura/escritura sobre el bucket).
R2_ACCESS_KEY_ID=
# Secret Access Key del mismo token R2.
R2_SECRET_ACCESS_KEY=
# Opcional: endpoint S3 custom. Si se deja vacio se construye como
# https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=
