# Copia este archivo a `.env` (docker compose lo lee solo) y cambia los
# valores. NUNCA commitees el `.env` real.
#
# Genera secretos fuertes con:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"

# --- base de datos del emulador (docker-compose) ---
POSTGRES_USER=emulador
POSTGRES_PASSWORD=cambia-esta-contrasena
POSTGRES_DB=emulador

# --- backend ---
# Clave de firma de los JWT (string largo y aleatorio)
JWT_SECRET=dev-only-change-me
# API key que el harvester manda en el header X-API-Key (string largo y aleatorio)
INGEST_API_KEY=dev-only-ingest-key
# Orígenes permitidos para CORS (la app Angular). En el deploy split = dominio del front.
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
# true solo detrás de HTTPS (las cookies llevan Secure)
COOKIE_SECURE=false
# "lax" para mismo sitio/local; "none" para deploy cross-site (requiere COOKIE_SECURE=true)
COOKIE_SAMESITE=lax

# --- feature toggles (defaults; Flagsmith puede sobreescribir en runtime) ---
# Esquema Timescale: lo leen las MIGRACIONES y debe coincidir con la DB.
# true = imagen timescaledb self-host (dev). false = Postgres plano (free tier).
TIMESCALE_ENABLED=true
# Registro público abierto. En prod: false + crea un usuario demo.
REGISTRATION_ENABLED=true
# Sirve /docs, /redoc, /openapi.json. Apaga en prod.
ENABLE_DOCS=true

# --- Flagsmith (cliente, lo usa el backend) ---
# Server-side environment key. El servicio flagsmith-seed crea esta MISMA key
# automáticamente al levantar el stack (dev). Déjalo vacío para deshabilitar
# Flagsmith y usar solo los toggles de arriba. En prod usa una key real.
FLAGSMITH_KEY=ser.trading-emulator-local-seed-key
# URL del Flagsmith self-host en la red de docker. Vacío = Flagsmith SaaS.
FLAGSMITH_API_URL=http://flagsmith:8000/api/v1/

# --- Flagsmith self-host (servicio en docker-compose) ---
# Postgres propio de Flagsmith (aislado de la DB del emulador)
FLAGSMITH_POSTGRES_USER=flagsmith
FLAGSMITH_POSTGRES_PASSWORD=cambia-esta-contrasena
FLAGSMITH_POSTGRES_DB=flagsmith
# Secreto de Django de Flagsmith (string largo y aleatorio)
FLAGSMITH_DJANGO_SECRET_KEY=cambia-este-secreto
# Admin que crea el seed para gestionar los flags en el dashboard (:8001)
FLAGSMITH_ADMIN_EMAIL=admin@example.com
FLAGSMITH_ADMIN_PASSWORD=cambia-esta-contrasena

# --- usuario demo (seed con backend/scripts/create_user.py) ---
DEMO_USERNAME=demo
DEMO_PASSWORD=cambia-esta-contrasena

# --- harvester (corre en el host Windows, fuera de Docker) ---
# URL del backend al que postea (en deploy = la URL pública del backend)
BACKEND_URL=http://127.0.0.1:8000
# Símbolos a cosechar = el catálogo que verán los usuarios (separados por coma).
HARVEST_SYMBOLS=US30,XAUUSD
# Temporalidades por defecto (usa --all-tfs en la CLI para los 21 timeframes).
HARVEST_TFS=M1,M5,M15,H1,H4,D1
# Fecha desde la que descargar (el broker puede conservar menos).
HARVEST_DESDE=2024-01-01
